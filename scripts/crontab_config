# APEX 璇玑 自动周期配置
# 使用: crontab scripts/crontab_config
#
# 替代旧的 xuanji_evolution.sh (每小时)
# 新方案: 15分钟 + 2个额外周期

# 每15分钟: 快速PHI追踪 + git自动提交 + EvoMap同步
*/15 * * * * cd /Users/lihongxin/.openclaw/workspace && bash scripts/auto_reflux.sh >> /Users/lihongxin/.openclaw/workspace/auto_reflux.log 2>&1

# 每2小时: 完整Gist备份
0 */2 * * * cd /Users/lihongxin/.openclaw/workspace && bash scripts/gist_backup.sh >> /Users/lihongxin/.openclaw/workspace/gist_backup.log 2>&1

# 每天06:00: 深度猎食 (扫描trending)
0 6 * * * cd /Users/lihongxin/.openclaw/workspace && bash -c 'timeout 30 apex-ene/scavenger/target/release/scavenge github trending' >> /Users/lihongxin/.openclaw/workspace/scavenge_daily.log 2>&1
