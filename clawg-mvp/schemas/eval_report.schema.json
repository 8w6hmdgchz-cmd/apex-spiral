{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ClawG Eval Report",
  "type": "object",
  "required": ["task_id", "auto_verify", "llm_verify", "score_apex"],
  "properties": {
    "task_id": {"type": "string"},
    "trace_id": {"type": "string"},
    "auto_verify": {
      "type": "object",
      "required": ["score", "weight"],
      "properties": {
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "weight": {"type": "number", "const": 0.6},
        "checks": {"type": "array", "items": {"type": "string"}}
      }
    },
    "llm_verify": {
      "type": "object",
      "required": ["score", "weight"],
      "properties": {
        "score": {"type": "number", "minimum": 0, "maximum": 1},
        "weight": {"type": "number", "const": 0.4},
        "judge_model": {"type": "string"},
        "rubric": {"type": "object"}
      }
    },
    "score_apex": {"type": "number", "minimum": 0, "maximum": 1},
    "breakdown": {"type": "object"}
  }
}
