{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "APEX Evidence Record",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "claim", "source_repo", "source_commit", "source_path", "context_id", "score", "verification"],
  "properties": {
    "id": {"type":"string", "minLength": 3, "pattern": "^[A-Za-z0-9_.:-]+$"},
    "claim": {"type":"string", "minLength": 12},
    "source_repo": {"type":"string", "minLength": 3},
    "source_commit": {"type":"string", "pattern": "^[0-9a-f]{7,40}$"},
    "source_path": {"type":"string", "minLength": 1, "not": {"pattern": "(^/|\\.\\.)"}},
    "context_id": {"type":"string", "minLength": 3},
    "score": {"type":"number", "minimum": 0, "maximum": 1},
    "verification": {
      "type":"object",
      "additionalProperties": false,
      "required": ["command", "result", "evidence_path"],
      "properties": {
        "command": {"type":"string", "minLength": 3},
        "result": {"type":"string", "enum": ["pass", "fail", "blocked"]},
        "evidence_path": {"type":"string", "minLength": 1, "not": {"pattern": "(^/|\\.\\.)"}}
      }
    },
    "memory_type": {"type":"string", "enum":["Working", "Procedural", "Semantic", "Episodic"]}
  }
}
